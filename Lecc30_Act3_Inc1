internal class Program
{
    private static void Main(string[] args)
    {
        int[] numerosEnteros = new int[15];
        bool existeRepetido = false;

        for (int i = 0; i < 15; i++)
        {
            Console.Write("Ingrese el numero " + (i + 1) + ": ");
            numerosEnteros[i] = Convert.ToInt32(Console.ReadLine());
        }

        for (int i = 0; i < 14; i++)
        {
            for (int comparador = i + 1; comparador < 15; comparador++)
            {
                if (numerosEnteros[i] == numerosEnteros[comparador])
                {
                    existeRepetido = true;
                }
            }
        }

        if (existeRepetido)
        {
            Console.WriteLine("Si existe al menos un numero repetido.");
        }
        else
        {
            Console.WriteLine("No existe ningun numero repetido.");
        }
    }
}
