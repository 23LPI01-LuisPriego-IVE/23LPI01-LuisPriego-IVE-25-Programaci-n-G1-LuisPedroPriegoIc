internal class Program
{
    private static void Main(string[] args)
    {
        int[] numerosEnteros = new int[8];
        int numeroMayor = 0;
        int posicionMayor = 0;

        for (int i = 0; i < 8; i++)
        {
            Console.Write("Ingrese el numero " + (i + 1) + ": ");
            numerosEnteros[i] = Convert.ToInt32(Console.ReadLine());

            if (i == 0)
            {
                numeroMayor = numerosEnteros[i];
                posicionMayor = i + 1;
            }
            else
            {
                if (numerosEnteros[i] > numeroMayor)
                {
                    numeroMayor = numerosEnteros[i];
                    posicionMayor = i + 1;
                }
            }
        }

        Console.WriteLine("El numero mayor es: " + numeroMayor);
        Console.WriteLine("Se encuentra en la posicion: " + posicionMayor);
    }
}
